# ============================================================
# BE — NestJS
# ============================================================

# Build output (tsconfig.json → outDir: ./dist)
be/dist/

# TypeScript incremental build info
be/*.tsbuildinfo

# Dependencies
be/node_modules/

# Prisma generated client (generator output → prisma/generated/client)
be/prisma/generated/

# ============================================================
# FE — Next.js
# ============================================================

# Build output
fe/.next/
fe/out/

# Dependencies
fe/node_modules/

# Vercel deploy config
fe/.vercel/

# Next.js cache
fe/.swc/

# ============================================================
# Test & Coverage
# ============================================================
coverage/
be/coverage/
fe/coverage/

# ============================================================
# Logs (tất cả vị trí)
# ============================================================
be/logs/
fe/logs/

# ============================================================
# AI / MCP / Dev Tools — local runtime, không commit
# ============================================================

# Playwright MCP — lưu browser sessions, console logs, page snapshots
.playwright-mcp/

# ============================================================
# Screenshots & audit artifacts
# ============================================================
screens/

# ============================================================
# Root node_modules (workspace root)
# ============================================================
/node_modules/

# ============================================================
# Prisma one-off scripts (fix-*.ts, seed scripts tạm)
# ============================================================
be/prisma/fix-*.ts
be/prisma/update-*.ts
be/prisma/data-resetting.prisma.ts

# ============================================================
# Agent — Python AI service
# ============================================================
agent/.env
agent/.venv/
agent/data/*.db
agent/data/*.sqlite
agent/data/*.sqlite3
# SQLite WAL/SHM runtime + catalog đồng bộ tự động — không commit
agent/data/*.sqlite-shm
agent/data/*.sqlite-wal
agent/data/products.json
# BE uploads local fallback (ảnh chạy qua Cloudinary)
be/uploads/
agent/**/__pycache__/
agent/.pytest_cache/
.opencode

# Server-admin runtime state (metrics history, audit, deploy log)
be/storage/
/*.png
.playwright-mcp/
agent/data/knowledge.local.md
agent/data/chat_limits.local.json
