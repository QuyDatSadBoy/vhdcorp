// VHD Corp Database Schema
// Spec: docs/DATABASE.md — 9 models, 5 enums, soft delete on User/Product/Post

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
  output        = "../node_modules/@vhd/prisma-client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ConfigStatus {
  DRAFT
  PUBLISHED
}

enum ContactStatus {
  NEW
  HANDLED
}

// ─── User ──────────────────────────────────────────────────────────────────

model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  password         String?
  name             String    @default("")
  role             Role      @default(CUSTOMER)
  avatar           String?
  /// SĐT + địa chỉ giao hàng — gợi ý tự điền khi khách đặt đơn
  phone            String?
  address          String?
  googleId         String?   @unique
  refreshTokenHash String?
  /// Tài khoản quản trị TỐI CAO — không ai xóa/đổi role/reset mật khẩu được (kể cả ADMIN khác)
  isRoot           Boolean   @default(false)
  /// Thời điểm xác minh email (đăng ký phải xác minh bằng mã OTP gửi về email thật)
  emailVerifiedAt  DateTime?
  /// Mã xác minh email (bcrypt hash) + hạn dùng
  verifyCodeHash      String?
  verifyCodeExpiresAt DateTime?
  /// Mã quên mật khẩu (bcrypt hash) + hạn dùng
  resetCodeHash      String?
  resetCodeExpiresAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  orders  Order[]
  reviews Review[]
  posts   Post[]

  @@index([deletedAt])
  @@map("users")
}

/// Sự kiện xem sản phẩm — nền tảng tracking & recommendation (khách nhận diện bằng sessionId từ localStorage)
model ViewEvent {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sessionId String
  userId    Int?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("view_events")
}

// ─── Category (cây đa cấp) ─────────────────────────────────────────────────

model Category {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  name        String
  image       String?
  description String?    @db.Text
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  parentId    Int?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  products Product[]

  @@index([parentId])
  @@map("categories")
}

// ─── Product ───────────────────────────────────────────────────────────────

model Product {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  name        String
  description String        @db.Text
  price       Decimal       @db.Decimal(12, 2)
  /// Giá khuyến mãi (kiểu Shopee) — hiển thị khi có giá trị và saleEndsAt còn hạn
  salePrice   Decimal?      @db.Decimal(12, 2)
  saleEndsAt  DateTime?
  stock       Int           @default(0)
  images      String[]
  categoryId  Int
  category    Category      @relation(fields: [categoryId], references: [id])
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  reviews    Review[]
  viewEvents ViewEvent[]
  orderItems OrderItem[]

  @@index([categoryId])
  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("products")
}

// ─── Post (Tiptap rich text) ───────────────────────────────────────────────

model Post {
  id          Int        @id @default(autoincrement())
  slug        String     @unique
  title       String
  content     String     @db.Text
  excerpt     String?    @db.Text
  coverImage  String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  tags        String[]
  authorId    Int
  author      User       @relation(fields: [authorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([authorId])
  @@map("posts")
}

// ─── Review ────────────────────────────────────────────────────────────────

model Review {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product      @relation(fields: [productId], references: [id])
  userId    Int
  user      User         @relation(fields: [userId], references: [id])
  rating    Int
  content   String       @db.Text
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([productId, userId])
  @@index([status])
  @@index([productId])
  @@map("reviews")
}

// ─── Contact (liên hệ khách hàng) ──────────────────────────────────────────

model Contact {
  id        Int           @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contacts")
}

// ─── Banner ────────────────────────────────────────────────────────────────

model Banner {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  link      String?
  alt       String?
  position  String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position, active])
  @@map("banners")
}

// ─── Media (Cloudinary metadata) ───────────────────────────────────────────

model Media {
  id         Int      @id @default(autoincrement())
  url        String
  publicId   String   @unique
  folder     String
  format     String
  width      Int?
  height     Int?
  bytes      Int?
  tags       String[]
  uploadedBy Int
  createdAt  DateTime @default(now())

  @@index([folder])
  @@map("media")
}

// ─── SiteConfig (JSONB toàn bộ giao diện) ──────────────────────────────────

model SiteConfig {
  id        Int          @id @default(autoincrement())
  key       String       @default("main")
  value     Json
  version   Int          @default(1)
  status    ConfigStatus @default(DRAFT)
  updatedBy Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  history SiteConfigHistory[]

  @@unique([key, status])
  @@index([key, status])
  @@map("site_configs")
}

model SiteConfigHistory {
  id        Int        @id @default(autoincrement())
  configId  Int
  config    SiteConfig @relation(fields: [configId], references: [id])
  snapshot  Json
  version   Int
  savedBy   Int
  createdAt DateTime   @default(now())

  @@index([configId])
  @@map("site_config_histories")
}


/// ── Voucher giảm giá (admin quản lý: loại %/tiền, hạn, số lượt) ──
enum VoucherType {
  PERCENT
  FIXED
}

model Voucher {
  id        Int         @id @default(autoincrement())
  code      String      @unique
  type      VoucherType @default(PERCENT)
  /// PERCENT: 1-100 (%); FIXED: số tiền VND
  value     Decimal     @db.Decimal(12, 2)
  /// Giá trị đơn tối thiểu để áp dụng (VND) — 0 = không giới hạn
  minOrder  Decimal     @default(0) @db.Decimal(12, 2)
  /// Tổng số lượt dùng tối đa — 0 = không giới hạn
  maxUses   Int         @default(0)
  usedCount Int         @default(0)
  startsAt  DateTime    @default(now())
  endsAt    DateTime
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  orders Order[]

  @@index([code, active])
  @@map("vouchers")
}

/// ── Đơn hàng (không thanh toán online — admin nhận mail và liên hệ chốt) ──
enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DONE
  CANCELLED
}

model Order {
  id          Int         @id @default(autoincrement())
  /// Mã đơn hiển thị cho khách (VHD-xxxxx)
  code        String      @unique
  name        String
  email       String
  phone       String
  address     String
  note        String?     @db.Text
  status      OrderStatus @default(PENDING)
  /// Tổng tiền hàng trước giảm (snapshot server-side)
  subtotal    Decimal     @db.Decimal(14, 2)
  discount    Decimal     @default(0) @db.Decimal(14, 2)
  total       Decimal     @db.Decimal(14, 2)
  voucherId   Int?
  voucher     Voucher?    @relation(fields: [voucherId], references: [id])
  voucherCode String?
  userId      Int?
  user        User?       @relation(fields: [userId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([email])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  /// Snapshot tại thời điểm đặt — đổi giá sau này không ảnh hưởng đơn cũ
  name      String
  price     Decimal @db.Decimal(12, 2)
  qty       Int

  @@index([orderId])
  @@map("order_items")
}
