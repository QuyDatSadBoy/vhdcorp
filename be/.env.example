# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
FRONTEND_URL=http://localhost:3001

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:datsql09@localhost:5432/vhdcorp_dev

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_64_chars_random
JWT_REFRESH_SECRET=change_me_refresh_secret_min_64_chars_random
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Cookie ─────────────────────────────────────────────────
COOKIE_SECRET=change_me_cookie_secret_min_64_chars_random
COOKIE_DOMAIN=localhost

# ─── Google OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=vhdcorp_unsigned

# ─── Mail (SMTP) ─────────────────────────────────────────────
# Để trống SMTP_HOST/USER/PASS → dry-run (log [MAIL:DRY-RUN], không gửi thật)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="VHD Corp <vhdcorp.contact@gmail.com>"
ADMIN_EMAIL=
# Thông tin liên hệ VHD hiển thị trong email khách (để trống → ẩn khối "Cần hỗ trợ ngay?")
CONTACT_HOTLINE=0879.744.888
CONTACT_EMAIL=vhdcorp.contact@gmail.com

# ─── Rate Limiting ───────────────────────────────────────────
THROTTLE_TTL=10000
THROTTLE_LIMIT=20

# AI Agent (FastAPI :8001) — push resync catalog + proxy knowledge cho admin
AGENT_URL=http://localhost:8001
AGENT_RESYNC_SECRET=vhdcorp-resync
AGENT_ADMIN_SECRET=vhdcorp-admin
MAIL_LOGO_URL=
MAIL_COMPANY_ADDRESS=Hà Nội, Việt Nam · Hotline: 0879.744.888
