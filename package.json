{
  "name": "vhdcorp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "description": "VHD Corp — Next.js 16 (fe) + NestJS 11 (be) monorepo",
  "scripts": {
    "prepare": "husky",
    "lint:fe": "corepack yarn --cwd fe lint",
    "lint:be": "corepack yarn --cwd be lint",
    "format": "prettier --write \"{fe,be,docs}/**/*.{ts,tsx,js,json,md,css}\"",
    "format:check": "prettier --check \"{fe,be,docs}/**/*.{ts,tsx,js,json,md,css}\""
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "fe/**/*.{ts,tsx}": [
      "corepack yarn --cwd fe lint --fix",
      "prettier --write"
    ],
    "be/**/*.ts": [
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
