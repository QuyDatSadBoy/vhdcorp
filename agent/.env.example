# Gemini
GOOGLE_API_KEY=your-google-api-key
AGENT_MODEL=gemini-3-flash-preview

# Tavily — nhiều key phân tách bằng dấu phẩy, tự xoay vòng khi rate-limit
TAVILY_API_KEYS=tvly-key-1,tvly-key-2

# Backend NestJS
BE_API_URL=http://localhost:8080/api

# Service
PORT=8001
CORS_ORIGINS=http://localhost:3001
SHORT_TERM_LIMIT=8
# URL công khai (dùng cho Agent Card A2A)
PUBLIC_BASE_URL=http://localhost:8001

# LangSmith tracing (observability)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=vhdcorp-agent

# MiniMax TTS (voice reply) — GroupId chỉ cần với một số vùng
MINIMAX_API_KEY=your-minimax-key
MINIMAX_GROUP_ID=

# Admin endpoints — bí mật bảo vệ resync sản phẩm & đọc email
RESYNC_SECRET=vhdcorp-resync
ADMIN_SECRET=vhdcorp-admin

# Gmail IMAP (đọc hộp thư admin qua /api/admin/emails) — dùng App Password 16 ký tự (bỏ khoảng trắng)
GMAIL_IMAP_USER=your-mailbox@gmail.com
GMAIL_IMAP_PASSWORD=your-16-char-app-password
GMAIL_IMAP_HOST=imap.gmail.com
